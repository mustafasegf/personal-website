---
import "@/styles/global.css";
import { Nav } from "@/components/Nav";
import { Footer } from "@/components/Footer";
import { ScrollToTop } from "@/components/ScrollToTop";
import { site } from "@/data/site";

const domain = import.meta.env.DOMAIN ?? "https://mustafasegf.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{site.title}</title>
    <meta name="description" content={site.description} />

    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:image" content={domain + "/images/hero-illustration.png"} />
    <meta property="og:url" content={domain} />
    <meta property="og:type" content="website" />

    <meta property="twitter:title" content={site.title} />
    <meta property="twitter:description" content={site.description} />
    <meta property="twitter:card" content="summary" />
    <meta name="twitter:image" content={domain + "/images/hero-illustration.png"} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Set theme before paint: light by default, dark only when the user chose it -->
    <script is:inline>
      if (localStorage.getItem("theme") === "dark") {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>

  <body>
    <Nav client:load />
    <main>
      <slot />
    </main>
    <Footer />
    <ScrollToTop client:load />

    <script>
      import { fastScrollTo } from "@/lib/scroll";

      // native smooth scroll has no speed control and crawls over long distances
      document.addEventListener("click", (e) => {
        const anchor = (e.target as Element).closest?.('a[href^="#"]');
        const target = anchor && document.querySelector(anchor.getAttribute("href")!);
        if (!target) return;

        e.preventDefault();
        history.pushState(null, "", anchor.getAttribute("href"));

        const margin = parseFloat(getComputedStyle(target).scrollMarginTop) || 0;
        // recompute the target each frame: lazy-loaded images shift the layout mid-scroll
        fastScrollTo(() => target.getBoundingClientRect().top + scrollY - margin);
      });
    </script>
  </body>
</html>
