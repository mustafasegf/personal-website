---
import { site } from "@/data/site";
---

<section id="top" class="grid border-b-2 md:grid-cols-12">
  <div class="flex flex-col justify-center gap-6 px-5 py-14 sm:px-10 md:col-span-7 md:py-20 lg:px-16">
    <p class="text-lg">Hi, my name is</p>
    <h1 class="max-w-xl text-3xl font-medium leading-snug sm:text-4xl lg:text-5xl lg:leading-snug">
      {site.name}. Backend, Cloud, and System Engineer.
    </h1>
    <p class="text-lg">I craft fast, reliable, and secure web application for a living</p>

    <div class="mt-2 flex flex-col gap-4 sm:flex-row">
      <a
        href="#projects"
        class="btn-brutal inline-flex h-12 items-center justify-center gap-2 bg-primary px-8 text-sm font-medium text-primary-foreground"
      >
        Learn More
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 5v14m0 0 6-6m-6 6-6-6"></path>
        </svg>
      </a>
      <a
        href="#contact"
        class="btn-brutal inline-flex h-12 items-center justify-center gap-2 bg-background px-8 text-sm font-medium"
      >
        Contact Me
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m2 7 10 6L22 7"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="flex flex-col items-center justify-center gap-4 border-t-2 bg-brand-yellow px-6 py-12 md:col-span-5 md:border-t-0 md:border-l-2">
    <div class="relative w-full max-w-sm sm:max-w-md">
      <img
        src="/images/hero-illustration.png"
        alt="Cartoon avatar of Mustafa surrounded by TypeScript, Rust, and Go stickers"
        width="603"
        height="641"
        loading="eager"
        class="w-full"
      />
      <!-- Overlay shares the illustration's 603x641 viewBox, so the glasses track the eyes at any rendered size -->
      <svg
        data-shade
        aria-hidden="true"
        viewBox="0 0 603 641"
        class="pointer-events-none absolute inset-0 h-full w-full select-none opacity-0 transition-opacity duration-300"
      >
        <text x="277" y="352" font-size="105" text-anchor="middle" dominant-baseline="central">🕶</text>
      </svg>
    </div>

    <button
      type="button"
      data-shade-toggle
      class="btn-brutal inline-flex cursor-pointer items-center gap-2 rounded-full! bg-background px-5 py-2.5 text-sm font-medium"
    >
      <span data-shade-label>Add Shade</span> 🕶
    </button>
  </div>
</section>

<script>
  const shade = document.querySelector<HTMLElement>("[data-shade]")!;
  const label = document.querySelector<HTMLElement>("[data-shade-label]")!;
  const toggle = document.querySelector<HTMLButtonElement>("[data-shade-toggle]")!;

  toggle.addEventListener("click", () => {
    const on = shade.classList.toggle("opacity-0");
    label.textContent = on ? "Add Shade" : "Remove Shade";
  });
</script>
