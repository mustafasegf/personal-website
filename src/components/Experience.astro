---
import { experience } from "@/data/site";
---

<section id="experience" class="grid scroll-mt-16 border-b-2 md:grid-cols-12">
  <div class="space-y-4 border-b-2 bg-brand-yellow px-5 py-12 sm:px-10 md:col-span-4 md:border-r-2 md:border-b-0 lg:col-span-3">
    <div class="md:sticky md:top-24 md:space-y-4">
      <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="12" rx="1"></rect>
        <path d="M2 20h20"></path>
      </svg>
      <h2 class="text-2xl font-semibold sm:text-3xl">My experiences</h2>
      <p class="text-sm leading-relaxed">
        List of all of my professional experiences, totalling around 5 years of experience.
      </p>
    </div>
  </div>

  <div class="px-5 py-12 sm:px-10 md:col-span-8 lg:col-span-9">
    <ol class="relative ml-2 space-y-10 border-l-2">
      {
        experience.map((e) => (
          <li class="relative pl-8">
            <span class="absolute top-1 -left-2 size-4 rounded-full border-2 border-border bg-brand-salmon" aria-hidden="true" />
            <time class="text-sm text-muted-foreground">{e.range}</time>
            <h3 class="mt-1 text-lg font-semibold">
              {e.role}{" "}
              {e.href ? (
                <a
                  href={e.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline decoration-2 underline-offset-4 hover:decoration-brand-salmon"
                >
                  @{e.company}
                </a>
              ) : (
                <span>@{e.company}</span>
              )}
            </h3>
            {e.desc && <p class="mt-1 text-sm italic">{e.desc}</p>}
            <ul class="mt-2 list-disc space-y-1.5 pl-5 text-sm leading-relaxed">
              {e.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </div>
</section>
