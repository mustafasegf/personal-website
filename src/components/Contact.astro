---
import { site } from "@/data/site";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { Label } from "@/components/ui/label";

const socials = [
  {
    name: "GitHub",
    href: site.github,
    icon: `<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.77 0c2.2-1.49 3.16-1.18 3.16-1.18.63 1.59.24 2.76.12 3.05.74.81 1.18 1.83 1.18 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.67.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>`,
  },
  {
    name: "X (Twitter)",
    href: site.x,
    icon: `<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93Zm-1.29 19.5h2.04L6.49 3.24H4.3l13.31 17.41Z"/></svg>`,
  },
  {
    name: "LinkedIn",
    href: site.linkedin,
    icon: `<svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05a3.75 3.75 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z"/></svg>`,
  },
  {
    name: "Email",
    href: `mailto:${site.email}`,
    icon: `<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6L22 7"/></svg>`,
  },
];
---

<section id="contact" class="grid scroll-mt-16 md:grid-cols-12">
  <div class="bg-brand-pink px-5 py-12 sm:px-10 md:col-span-8">
    <h2 class="text-2xl font-semibold sm:text-3xl">Let's Talk</h2>
    <p class="mt-3 text-sm">
      If you want to reach out or just want to say hi, you can contact me directly through the form
      below.
    </p>

    <form data-contact-form class="mt-8 max-w-2xl space-y-5">
      <div class="space-y-2">
        <Label htmlFor="name">Your Name</Label>
        <Input
          id="name"
          name="name"
          type="text"
          required
          placeholder="Enter your name..."
          className="h-11 border-2 bg-background"
        />
      </div>
      <div class="space-y-2">
        <Label htmlFor="email">Your Email</Label>
        <Input
          id="email"
          name="email"
          type="email"
          required
          placeholder="Enter your email..."
          className="h-11 border-2 bg-background"
        />
      </div>
      <div class="space-y-2">
        <Label htmlFor="message">Your Message</Label>
        <Textarea
          id="message"
          name="message"
          required
          placeholder="Enter your message..."
          className="min-h-32 border-2 bg-background"
        />
      </div>

      <button
        type="submit"
        class="btn-brutal inline-flex h-12 w-full cursor-pointer items-center justify-center bg-primary text-sm font-medium text-primary-foreground disabled:pointer-events-none disabled:opacity-60"
      >
        Submit
      </button>

      <p data-form-status role="status" aria-live="polite" class="hidden text-sm font-medium"></p>
    </form>
  </div>

  <div class="border-t-2 bg-brand-blue px-5 py-12 sm:px-10 md:col-span-4 md:border-t-0 md:border-l-2">
    <h2 class="text-2xl font-semibold sm:text-3xl">Connect on Socials</h2>
    <p class="mt-3 text-sm">You can also contact me through these links</p>
    <ul class="mt-8 flex flex-wrap gap-4 md:flex-col md:gap-6">
      {
        socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-3"
            >
              <span class="btn-brutal inline-flex size-11 items-center justify-center rounded-full! bg-primary text-primary-foreground">
                <Fragment set:html={s.icon} />
              </span>
              <span class="text-sm font-medium group-hover:underline group-hover:underline-offset-4">
                {s.name}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]")!;
  const status = document.querySelector<HTMLElement>("[data-form-status]")!;
  const submit = form.querySelector<HTMLButtonElement>("button[type=submit]")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    submit.disabled = true;
    submit.textContent = "Sending...";
    status.classList.add("hidden");

    try {
      const res = await fetch("https://api.emailjs.com/api/v1.0/email/send", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          service_id: "personal_website",
          template_id: "template_personal_form",
          user_id: "2h-h0QZiLxIp5SaXE",
          template_params: {
            from_name: data.get("name"),
            from_email: data.get("email"),
            message: data.get("message"),
          },
        }),
      });

      if (!res.ok) throw new Error(await res.text());
      status.textContent = "Message sent successfully. Thanks for reaching out!";
      form.reset();
    } catch (err) {
      status.textContent = "Something went wrong sending the message. You can email me directly instead.";
      console.error(err);
    } finally {
      status.classList.remove("hidden");
      submit.disabled = false;
      submit.textContent = "Submit";
    }
  });
</script>
