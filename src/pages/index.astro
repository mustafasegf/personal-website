---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import Layout from "@/layouts/Layout.astro";
import { Hero } from "@/components/Hero";
import { About } from "@/components/About";
import { FeaturedProjects } from "@/components/FeaturedProjects";
import { ProjectGrid } from "@/components/ProjectGrid";
import { Experience } from "@/components/Experience";
import { Contact } from "@/components/Contact";
import { showcase, type Img } from "@/data/site";
import heroIllustration from "@/assets/hero-illustration.png";

// framework components can't render <Image>, so optimize here and pass the results down
const optimize = async (img: ImageMetadata): Promise<Img> => {
  const { src, attributes } = await getImage({ src: img, format: "webp" });
  return { src, width: attributes.width, height: attributes.height };
};

const illustration = await optimize(heroIllustration);
const showcaseImages = Object.fromEntries(
  await Promise.all(showcase.filter((p) => p.img).map(async (p) => [p.title, await optimize(p.img!)])),
);
---

<Layout>
  <Hero illustration={illustration} />
  <About />
  <FeaturedProjects images={showcaseImages} />
  <ProjectGrid />
  <Experience />
  <Contact />
</Layout>
